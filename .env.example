# ─── Server ────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database (PostgreSQL) ────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medwell
DB_USER=postgres
DB_PASSWORD=your_password

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=change_this_to_a_secure_random_string
JWT_EXPIRES_IN=7d

# ─── i18n ─────────────────────────────────────────────
DEFAULT_LANG=en
SUPPORTED_LANGS=ar,fr,en,es

# ─── WhatsApp / Twilio ───────────────────────────────
WHATSAPP_NUMBER=+212xxxxxxxxx
WHATSAPP_API_KEY=your_twilio_api_key

# ─── n8n Webhook ─────────────────────────────────────
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/medwell
N8N_API_KEY=your_n8n_api_key

# ─── File Upload ──────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ─── Payment Provider (Stripe placeholder) ───────────
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# ─── SMTP (Email) ─────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@medwell.ma
CLIENT_URL=http://localhost:5173
